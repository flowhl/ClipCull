<Window x:Class="ClipCull.Controls.ClipPointEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClipCull.Controls"
        Title="Edit Clip Point"
        Width="420"
        MinWidth="380"
        SizeToContent="Height"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource ForegroundBrush}"
        FontFamily="{StaticResource FontSans}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False">

    <Border Style="{StaticResource card}" Margin="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0"
                      Text="Edit Clip Point Details"
                      Style="{StaticResource h4}"
                      Margin="0,0,0,16"/>

            <!-- Clip Point Title -->
            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                          Text="Title"
                          Style="{StaticResource small}"
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"/>

                <TextBox x:Name="TitleTextBox"
                        Grid.Column="1"
                        Style="{StaticResource input}"
                        Padding="8,6"
                        MaxLength="100"/>
            </Grid>

            <!-- Type -->
            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                          Text="Type"
                          Style="{StaticResource small}"
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"/>

                <ComboBox x:Name="TypeComboBox"
                         Grid.Column="1">
                    <ComboBoxItem Content="In Point"/>
                    <ComboBoxItem Content="Out Point"/>
                </ComboBox>
            </Grid>

            <!-- Timestamp -->
            <Grid Grid.Row="3" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                          Text="Time"
                          Style="{StaticResource small}"
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"/>

                <TextBox x:Name="TimestampTextBox"
                        Grid.Column="1"
                        Style="{StaticResource input}"
                        Padding="8,6"
                        FontFamily="{StaticResource FontMono}"
                        ToolTip="Format: HH:MM:SS.mmm"/>
            </Grid>

            <!-- Current Time Display -->
            <TextBlock Grid.Row="4"
                      x:Name="CurrentTimeLabel"
                      Text="Current position: 00:00:00.000"
                      Style="{StaticResource muted}"
                      FontFamily="{StaticResource FontMono}"
                      FontSize="11"
                      Margin="0,0,0,15"/>

            <!-- Spacer -->
            <Grid Grid.Row="5"/>

            <!-- Buttons -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                       x:Name="DeleteButton"
                       Content="Delete"
                       Click="DeleteButton_Click"
                       Style="{StaticResource destructive}"/>

                <Button Grid.Column="2"
                       x:Name="CancelButton"
                       Content="Cancel"
                       Click="CancelButton_Click"
                       Style="{StaticResource secondary}"
                       Margin="0,0,8,0"/>

                <Button Grid.Column="3"
                       x:Name="OkButton"
                       Content="OK"
                       Click="OkButton_Click"
                       Style="{StaticResource primary}"
                       MinWidth="72"
                       IsDefault="True"/>
            </Grid>
        </Grid>
    </Border>
</Window>
