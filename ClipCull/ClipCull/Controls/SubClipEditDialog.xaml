<Window x:Class="ClipCull.Controls.SubClipEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClipCull.Controls"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Edit SubClip"
        Width="460"
        MinWidth="420"
        SizeToContent="Height"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource ForegroundBrush}"
        FontFamily="{StaticResource FontSans}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False">

    <Border Style="{StaticResource card}" Margin="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0"
                      Text="Edit SubClip Details"
                      Style="{StaticResource h4}"
                      Margin="0,0,0,16"/>

            <!-- SubClip Title -->
            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                          Text="Title"
                          Style="{StaticResource small}"
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"/>

                <TextBox x:Name="TitleTextBox"
                        Grid.Column="1"
                        Style="{StaticResource input}"
                        Padding="8,6"
                        MaxLength="100"/>
            </Grid>

            <!-- Start Time -->
            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                          Text="Start Time"
                          Style="{StaticResource small}"
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"/>

                <TextBox x:Name="StartTimeTextBox"
                        Grid.Column="1"
                        Style="{StaticResource input}"
                        Padding="8,6"
                        FontFamily="{StaticResource FontMono}"
                        TextChanged="StartTimeTextBox_TextChanged"
                        ToolTip="Format: HH:MM:SS.mmm"/>
            </Grid>

            <!-- End Time -->
            <Grid Grid.Row="3" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                          Text="End Time"
                          Style="{StaticResource small}"
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"/>

                <TextBox x:Name="EndTimeTextBox"
                        Grid.Column="1"
                        Style="{StaticResource input}"
                        Padding="8,6"
                        FontFamily="{StaticResource FontMono}"
                        TextChanged="EndTimeTextBox_TextChanged"
                        ToolTip="Format: HH:MM:SS.mmm"/>
            </Grid>

            <!-- Duration Display -->
            <TextBlock Grid.Row="4"
                      x:Name="DurationLabel"
                      Text="Duration: --:--:--.---"
                      Style="{StaticResource muted}"
                      FontFamily="{StaticResource FontMono}"
                      FontSize="11"
                      Margin="0,0,0,10"/>

            <!-- Color -->
            <Grid Grid.Row="5" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                          Text="Color"
                          Style="{StaticResource small}"
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"/>

                <Rectangle x:Name="ColorPreview"
                          Grid.Column="1"
                          Width="30"
                          Height="20"
                          RadiusX="4"
                          RadiusY="4"
                          Stroke="{StaticResource BorderBrush}"
                          StrokeThickness="1"
                          Margin="0,0,10,0"/>

                <Button Grid.Column="3"
                       x:Name="ChangeColorButton"
                       Content="Change"
                       Click="ChangeColorButton_Click"
                       Style="{StaticResource secondary-sm}"/>
            </Grid>

            <!-- Rating -->
            <Grid Grid.Row="6" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Rating"
                           Style="{StaticResource small}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="RatingStar1" Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Width="24" Height="24" Margin="2" Click="RatingStar_Click" Tag="1">
                        <materialDesign:PackIcon x:Name="RatingStar1Icon" Kind="Star" Width="20" Height="20"
                                                 Foreground="{StaticResource MutedForegroundBrush}"/>
                    </Button>
                    <Button x:Name="RatingStar2" Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Width="24" Height="24" Margin="2" Click="RatingStar_Click" Tag="2">
                        <materialDesign:PackIcon x:Name="RatingStar2Icon" Kind="Star" Width="20" Height="20"
                                                 Foreground="{StaticResource MutedForegroundBrush}"/>
                    </Button>
                    <Button x:Name="RatingStar3" Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Width="24" Height="24" Margin="2" Click="RatingStar_Click" Tag="3">
                        <materialDesign:PackIcon x:Name="RatingStar3Icon" Kind="Star" Width="20" Height="20"
                                                 Foreground="{StaticResource MutedForegroundBrush}"/>
                    </Button>
                    <Button x:Name="RatingStar4" Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Width="24" Height="24" Margin="2" Click="RatingStar_Click" Tag="4">
                        <materialDesign:PackIcon x:Name="RatingStar4Icon" Kind="Star" Width="20" Height="20"
                                                 Foreground="{StaticResource MutedForegroundBrush}"/>
                    </Button>
                    <Button x:Name="RatingStar5" Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Width="24" Height="24" Margin="2" Click="RatingStar_Click" Tag="5">
                        <materialDesign:PackIcon x:Name="RatingStar5Icon" Kind="Star" Width="20" Height="20"
                                                 Foreground="{StaticResource MutedForegroundBrush}"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Current Time Display -->
            <TextBlock Grid.Row="7"
                      x:Name="CurrentTimeLabel"
                      Text="Current position: 00:00:00.000"
                      Style="{StaticResource muted}"
                      FontFamily="{StaticResource FontMono}"
                      FontSize="11"
                      Margin="0,0,0,15"/>

            <!-- Spacer -->
            <Grid Grid.Row="8"/>

            <!-- Buttons -->
            <Grid Grid.Row="9">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                       x:Name="DeleteButton"
                       Content="Delete"
                       Click="DeleteButton_Click"
                       Style="{StaticResource destructive}"/>

                <Button Grid.Column="2"
                       x:Name="CancelButton"
                       Content="Cancel"
                       Click="CancelButton_Click"
                       Style="{StaticResource secondary}"
                       Margin="0,0,8,0"/>

                <Button Grid.Column="3"
                       x:Name="OkButton"
                       Content="OK"
                       Click="OkButton_Click"
                       Style="{StaticResource primary}"
                       MinWidth="72"
                       IsDefault="True"/>
            </Grid>
        </Grid>
    </Border>
</Window>
